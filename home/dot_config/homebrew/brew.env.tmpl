# See https://docs.brew.sh/Manpage#environment

# Homebrew
HOMEBREW_ALLOWED_TAPS="hashicorp/tap nodenv/nodenv terraform-linters/tap"
HOMEBREW_CACHE={{ env "XDG_CACHE_HOME" }}/Homebrew
HOMEBREW_COLOR=1
HOMEBREW_CURLRC={{ env "XDG_CONFIG_HOME" }}/curlrc
HOMEBREW_LOGS={{ env "XDG_STATE_HOME" }}/Homebrew/Logs
HOMEBREW_NO_ANALYTICS=1
HOMEBREW_NO_EMOJI=1
HOMEBREW_NO_ENV_HINTS=1
HOMEBREW_REQUIRE_TAP_TRUST=1
HOMEBREW_UPGRADE_GREEDY=1
HOMEBREW_VERIFY_ATTESTATIONS=1

# Homebrew Cask
# See https://github.com/Homebrew/homebrew-cask/issues/147305
# HOMEBREW_CASK_OPTS="--require-sha"

# Homebrew Bundle
HOMEBREW_BUNDLE_USER_CACHE={{ env "XDG_CACHE_HOME" }}/Homebrew/bundler_cache # See https://github.com/Homebrew/brew/pull/17327
HOMEBREW_BUNDLE_DUMP_DESCRIBE=1
HOMEBREW_BUNDLE_INSTALL_CLEANUP=1
