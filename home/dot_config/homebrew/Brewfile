cask "logi-options+" # Software for Logitech devices
cask "naps2", args: { require_sha: true } # Document scanning application
cask "obsidian", args: { require_sha: true } # Knowledge base that works on top of a local folder of plain text Markdown files
# https://github.com/Homebrew/homebrew-cask/blob/main/Casks/o/onyx.rb#L2
cask "onyx" # Verify system files structure, run miscellaneous maintenance and more
